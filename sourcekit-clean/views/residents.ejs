<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Residents</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
</head>
<body class="bg-light">
<div class="container py-4">
  <h1 class="text-center mb-4">Resident List</h1>

  <% if (error) { %>
    <div class="alert alert-danger"><%= error %></div>
  <% } %>

  <button class="btn btn-primary mb-4" data-bs-toggle="modal" data-bs-target="#addModal">
    Add New Resident
  </button>

  <% if (residents.length > 0) { %>
    <div class="row">
      <% residents.forEach((r) => { %>
        <div class="col-md-4 mb-4">
          <div class="card h-100 shadow-sm">
            <div class="card-body">
              <h5 class="card-title"><%= r.residentName %></h5>
              <p class="card-text"><%= r.residentDescription %></p>
              <p class="card-text mb-1"><strong>Floor:</strong> <%= r.floor %></p>
              <p class="card-text mb-1"><strong>Age:</strong> <%= toAge(r.yOB) %> (YOB: <%= r.yOB %>)</p>
              <p class="card-text mb-1"><strong>Owned:</strong> <%= r.isOwned ? 'Yes' : 'No' %></p>
              <p class="card-text"><strong>Apartment:</strong> <%= r.apartment ? r.apartment.apartmentName : '' %></p>

              <button class="btn btn-warning btn-sm" data-bs-toggle="modal"
                      data-bs-target="#edit-<%= r._id %>">Edit</button>
              <button class="btn btn-danger btn-sm"
                      onclick="deleteResident('<%= r._id %>', '<%= r.residentName %>')">Delete</button>
            </div>
          </div>
        </div>

        <div class="modal fade" id="edit-<%= r._id %>" tabindex="-1">
          <div class="modal-dialog">
            <div class="modal-content">
              <form method="POST" action="/view/residents/<%= r._id %>">
                <div class="modal-header">
                  <h5 class="modal-title">Edit Resident</h5>
                  <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                  <div class="mb-3">
                    <label class="form-label">Resident Name</label>
                    <input class="form-control" name="residentName" required
                           pattern="[A-Za-z ]+" title="Only letters (a-z, A-Z) and space"
                           value="<%= r.residentName %>">
                  </div>
                  <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea class="form-control" name="residentDescription" required><%= r.residentDescription %></textarea>
                  </div>
                  <div class="mb-3">
                    <label class="form-label">Floor (1-40)</label>
                    <input type="number" class="form-control" name="floor" required
                           min="1" max="40" value="<%= r.floor %>">
                  </div>
                  <div class="mb-3">
                    <label class="form-label">Age (1-85)</label>
                    <input type="number" class="form-control" name="age" required
                           min="1" max="85" value="<%= toAge(r.yOB) %>">
                  </div>
                  <div class="mb-3 form-check form-switch">
                    <input class="form-check-input" type="checkbox" name="isOwned"
                           id="own-<%= r._id %>" <%= r.isOwned ? 'checked' : '' %>>
                    <label class="form-check-label" for="own-<%= r._id %>">Is Owned</label>
                  </div>
                  <div class="mb-3">
                    <label class="form-label">Apartment</label>
                    <select class="form-select" name="apartment" required>
                      <% apartments.forEach((a) => { %>
                        <option value="<%= a._id %>"
                          <%= r.apartment && r.apartment._id.toString() === a._id.toString() ? 'selected' : '' %>>
                          <%= a.apartmentName %>
                        </option>
                      <% }) %>
                    </select>
                  </div>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                  <button type="submit" class="btn btn-primary">Update</button>
                </div>
              </form>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <p class="text-center text-muted">No residents available.</p>
  <% } %>

  <div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <form method="POST" action="/view/residents">
          <div class="modal-header">
            <h5 class="modal-title">Add Resident</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body">
            <div class="mb-3">
              <label class="form-label">Resident Name</label>
              <input class="form-control" name="residentName" required
                     pattern="[A-Za-z ]+" title="Only letters (a-z, A-Z) and space">
            </div>
            <div class="mb-3">
              <label class="form-label">Description</label>
              <textarea class="form-control" name="residentDescription" required></textarea>
            </div>
            <div class="mb-3">
              <label class="form-label">Floor (1-40)</label>
              <input type="number" class="form-control" name="floor" required min="1" max="40">
            </div>
            <div class="mb-3">
              <label class="form-label">Age (1-85)</label>
              <input type="number" class="form-control" name="age" required min="1" max="85">
            </div>
            <div class="mb-3 form-check form-switch">
              <input class="form-check-input" type="checkbox" name="isOwned" id="own-new">
              <label class="form-check-label" for="own-new">Is Owned</label>
            </div>
            <div class="mb-3">
              <label class="form-label">Apartment</label>
              <select class="form-select" name="apartment" required>
                <option value="">-- Select Apartment --</option>
                <% apartments.forEach((a) => { %>
                  <option value="<%= a._id %>"><%= a.apartmentName %></option>
                <% }) %>
              </select>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary">Save</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  async function deleteResident(id, name) {
    if (!confirm(`Delete resident "${name}"?`)) return;
    try {
      const res = await fetch(`/view/residents/${id}`, { method: 'DELETE' });
      const data = await res.json();
      alert(data.message);
      location.reload();
    } catch (err) {
      alert('Delete failed: ' + err.message);
    }
  }
</script>
</body>
</html>
