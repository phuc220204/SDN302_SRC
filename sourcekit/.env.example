# ================= BẮT BUỘC THEO ĐỀ — THIẾU LÀ 0 ĐIỂM =================
# 1) PORT  2) MONGO_URI (đúng tên DB đề yêu cầu)  3) JWT_SECRET (đúng format đề)
PORT=3000

# [ĐỔI THEO ĐỀ] tên DB copy NGUYÊN VĂN từ đề, vd: SDN302_SP26_SE181834DB
MONGO_URI=mongodb://127.0.0.1:27017/SDN302_PE_SU25_SE181834DB

# [ĐỔI THEO ĐỀ] ĐỌC KỸ FORMAT: SP26 = StudentCode! | SU25 = StudentCode!! | FA25 = StudentCode!@
JWT_SECRET=SE181834!!

# Secret của express-session (KHÔNG phải JWT). Để trong .env cho sạch, không hardcode.
SESSION_SECRET=SE181834_session
