  "Mongoose Model": {
    "prefix": "!model",
    "scope": "javascript",
    "description": "Mongoose schema + timestamps + export",
    "body": [
      "const mongoose = require('mongoose');",
      "",
      "const ${1:item}Schema = new mongoose.Schema(",
      "  {",
      "    ${2:name}: {",
      "      type: String,",
      "      required: true,",
      "      unique: true,",
      "      match: [/^[A-Za-z ]+$/, 'Only letters (a-z, A-Z) and space are allowed'],",
      "    },",
      "    ${3:field}: { type: Number, required: true, min: ${4:1}, max: ${5:100} },",
      "    ${6:flag}: { type: Boolean, default: false },",
      "    ${7:parent}: { type: mongoose.Schema.Types.ObjectId, ref: '${7:parent}', required: true },",
      "  },",
      "  { timestamps: true }",
      ");",
      "",
      "module.exports = mongoose.model('${1:item}', ${1:item}Schema, '${1:item}s');"
    ]
  },
