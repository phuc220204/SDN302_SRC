  "CRUD Controller": {
    "prefix": "!crud",
    "scope": "javascript",
    "description": "CRUD controller 5 hàm + delete-guard",
    "body": [
      "const db = require('../models');",
      "",
      "const getAll = async (req, res, next) => {",
      "  try {",
      "    const items = await db.${1:Apartment}.find();",
      "    res.status(200).json({ status: 'success', data: items });",
      "  } catch (err) { next(err); }",
      "};",
      "",
      "const getById = async (req, res, next) => {",
      "  try {",
      "    const item = await db.${1:Apartment}.findById(req.params.id);",
      "    if (!item) return res.status(404).json({ message: '${1:Apartment} not found' });",
      "    res.status(200).json({ status: 'success', data: item });",
      "  } catch (err) { next(err); }",
      "};",
      "",
      "const create = async (req, res, next) => {",
      "  try {",
      "    const item = await db.${1:Apartment}.create({ ...req.body });",
      "    res.status(201).json({ status: 'success', data: item });",
      "  } catch (err) { next(err); }",
      "};",
      "",
      "const update = async (req, res, next) => {",
      "  try {",
      "    const item = await db.${1:Apartment}.findByIdAndUpdate(",
      "      req.params.id,",
      "      { ...req.body },",
      "      { new: true, runValidators: true }",
      "    );",
      "    if (!item) return res.status(404).json({ message: '${1:Apartment} not found' });",
      "    res.status(200).json({ status: 'success', data: item });",
      "  } catch (err) { next(err); }",
      "};",
      "",
      "const remove = async (req, res, next) => {",
      "  try {",
      "    const { id } = req.params;",
      "    const used = await db.${2:Resident}.findOne({ ${3:apartment}: id });",
      "    if (used) {",
      "      return res.status(400).json({ message: '${4:Cannot delete apartment because it has associated residents}' });",
      "    }",
      "    const deleted = await db.${1:Apartment}.findByIdAndDelete(id);",
      "    if (!deleted) return res.status(404).json({ message: '${1:Apartment} not found' });",
      "    res.status(200).json({ status: 'success', message: 'Delete successfully' });",
      "  } catch (err) { next(err); }",
      "};",
      "",
      "module.exports = { getAll, getById, create, update, remove };"
    ]
  },
  "CRUD Router": {
    "prefix": "!router",
    "scope": "javascript",
    "description": "Router CRUD gắn controller + protect",
    "body": [
      "const router = require('express').Router();",
      "const { protectApi } = require('../middlewares/auth.middleware');",
      "const c = require('../controllers/${1:apartment}.controller');",
      "",
      "router.use(protectApi);",
      "",
      "router.get('/', c.getAll);",
      "router.get('/:id', c.getById);",
      "router.post('/', c.create);",
      "router.put('/:id', c.update);",
      "router.delete('/:id', c.remove);",
      "",
      "module.exports = router;"
    ]
  },
